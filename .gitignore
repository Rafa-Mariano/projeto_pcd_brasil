# ============================================================================
# ARQUIVO .gitignore - ARQUIVOS A IGNORAR
# ============================================================================
# Este arquivo define quais arquivos/pastas NÃO devem ser versionados no Git

# ──────────────────────────────────────────────────────────────────────────
# Variáveis de Ambiente (senhas, credenciais)
# ──────────────────────────────────────────────────────────────────────────
.env

# ──────────────────────────────────────────────────────────────────────────
# Ambiente Virtual Python
# ──────────────────────────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.Python

# ──────────────────────────────────────────────────────────────────────────
# Cache Python
# ──────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ──────────────────────────────────────────────────────────────────────────
# IDE/Editor
# ──────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*.sublime-*
.DS_Store

# ──────────────────────────────────────────────────────────────────────────
# Dados Gerados
# ──────────────────────────────────────────────────────────────────────────
*.csv
*.xlsx
*.xls
*.db
*.sqlite
*.sqlite3

# ──────────────────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────────────────
*.log
logs/

# ──────────────────────────────────────────────────────────────────────────
# Streamlit Cache
# ──────────────────────────────────────────────────────────────────────────
.streamlit/
.streamlit/secrets.toml

# ──────────────────────────────────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store
*.exe
